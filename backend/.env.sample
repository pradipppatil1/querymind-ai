# MySQL Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=tiger
DB_NAME=hospital_billing

# Qdrant Configuration
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Your AWS Account ID (get with: aws sts get-caller-identity --query Account --output text)
AWS_ACCOUNT_ID=<<Your account Id>>

# Your default AWS region for most infrastructure (e.g., us-east-1, us-west-2, eu-west-1)
DEFAULT_AWS_REGION=ap-south-1

#Use Bedrock
USE_AWS_BEDROCK=false


# Hugging Face Configuration (Managed by User)
HF_TOKEN=<<Your Token>>

#OPENAI_API_KEY
OPENAI_API_KEY=<<Your Token>>



# JWT Configuration
JWT_SECRET=<<Your SECRET>>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7


## SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<<Your Email>>
SMTP_PASS=<<Your app password>>

##LangFuse
LANGFUSE_SECRET_KEY=<<Your secret>>
LANGFUSE_PUBLIC_KEY=<<Your Key>>
LANGFUSE_BASE_URL=<<As per your region>>